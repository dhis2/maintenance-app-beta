msgstr ""
"Specify code and attributes to enable easier data exchange with other "
"systems."

msgid "Group category options and improve analysis with category option group sets."
msgstr "Group category options and improve analysis with category option group sets."

msgid ""
"Classify category options groups to add more dimensionality to captured "
"data for analysis."
msgstr ""
"Classify category options groups to add more dimensionality to captured "
"data for analysis."

msgid "Data Approval"
msgstr "Data Approval"

msgid ""
"Data approval workflows create a process for authorized users to review and "
"approve data at specified levels."
msgstr ""
"Data approval workflows create a process for authorized users to review and "
"approve data at specified levels."

msgid "Configure data approval levels for use in data approval workflows."
msgstr "Configure data approval levels for use in data approval workflows."

